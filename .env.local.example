# ─────────────────────────────────────────────────────────
# ArmorClaw Environment Variables
# ─────────────────────────────────────────────────────────

# URL of your FastAPI backend (no trailing slash)
# When set, API routes will proxy to this instead of returning mock data
BACKEND_URL=http://localhost:8000

# Example production value:
# BACKEND_URL=https://api.armorclaw.yourdomain.com
